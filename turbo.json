{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "./tsconfig.json"
  ],
  "globalPassThroughEnv": [
    "CI",
    "COREPACK_INTEGRITY_KEYS",
    "COREPACK_NPM_REGISTRY",
    "COREPACK_DEFAULT_TO_LATEST",
    "GOCACHE",
    "GOMODCACHE",
    "GOPATH",
    "NODE_OPTIONS",
    "XDG_CACHE_HOME",
    "npm_config_cache"
  ],
  "ui": "tui",
  "tasks": {
    "api-extractor": {
      "dependsOn": [
        "//#build"
      ],
      "cache": false
    },
    "build": {
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "dependsOn": [],
      "cache": false
    },
    "//#build": {
      "cache": false,
      "dependsOn": [],
      "inputs": []
    }
  }
}
