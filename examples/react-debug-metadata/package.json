{
  "name": "@lynx-js/example-react-debug-metadata",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:producer && pnpm run build:consumer",
    "build:consumer": "cross-env DEBUG=rspeedy,rsbuild rspeedy build --config lynx.config.consumer.js",
    "build:producer": "cross-env DEBUG=rspeedy,rsbuild rspeedy build --config lynx.config.producer.js",
    "dev": "node scripts/serve.mjs dev",
    "dev:consumer": "rspeedy dev --config lynx.config.consumer.js",
    "dev:producer": "rspeedy dev --config lynx.config.producer.js",
    "preview": "node scripts/serve.mjs preview",
    "preview:consumer": "rspeedy preview --config lynx.config.consumer.js",
    "preview:producer": "rspeedy preview --config lynx.config.producer.js",
    "test": "rstest run --config error-remapping/rstest.config.ts",
    "test:update": "rstest run -u --config error-remapping/rstest.config.ts"
  },
  "dependencies": {
    "@lynx-js/react": "workspace:*"
  },
  "devDependencies": {
    "@lynx-js/preact-devtools": "5.0.1-20260716151326-abdb87c",
    "@lynx-js/qrcode-rsbuild-plugin": "workspace:*",
    "@lynx-js/react-rsbuild-plugin": "workspace:*",
    "@lynx-js/rspeedy": "workspace:*",
    "@lynx-js/types": "4.0.0",
    "@rstest/core": "catalog:rstest",
    "@types/react": "^19.2.17",
    "cross-env": "^10.1.0",
    "source-map": "^0.7.6"
  }
}
