{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": [],
      "inputs": [
        "debug/**",
        "jsx-dev-runtime/**",
        "jsx-runtime/**",
        "lepus/**",
        "src/**",
        "types/**",
        "tsconfig.json",
        "tsconfig.worklet-runtime.json"
      ],
      "outputs": [
        "lib/**",
        "tsconfig.tsbuildinfo",
        "tsconfig.worklet-runtime.tsbuildinfo"
      ]
    },
    "build:worklet-runtime": {
      "dependsOn": [],
      "inputs": [
        "src/worklet-runtime/**",
        "tsconfig.worklet-runtime.json"
      ],
      "outputs": [
        "lib/worklet-runtime/**",
        "tsconfig.worklet-runtime.tsbuildinfo"
      ]
    }
  }
}
