{
  "name": "@lynx-js/react-runtime",
  "version": "0.100.1",
  "private": true,
  "description": "All-in-one package for React on Lynx",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "jsx-dev-runtime",
    "jsx-runtime",
    "lazy",
    "lepus",
    "src"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "pnpm run test:snapshot && pnpm run test:core && pnpm run test:et",
    "test:core": "vitest run __test__/core",
    "test:et": "vitest run -c __test__/element-template/vitest.config.ts --coverage",
    "test:snapshot": "vitest run --coverage __test__/snapshot __test__/worklet-runtime __test__/guardrails"
  },
  "devDependencies": {
    "@lynx-js/react": "workspace:*",
    "@lynx-js/react-transform": "workspace:*",
    "@lynx-js/types": "3.7.0",
    "@types/react": "^19.2.14",
    "pretty-format": "^30.2.0"
  },
  "peerDependencies": {
    "@types/react": "^18.0.0 || ^19.0.0"
  },
  "showcase": "__fake_entry__/showcase.js"
}
