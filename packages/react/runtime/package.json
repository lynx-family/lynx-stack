{
  "name": "@lynx-js/react-runtime",
  "version": "0.100.1",
  "private": true,
  "description": "All-in-one package for React on Lynx",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "jsx-dev-runtime",
    "jsx-runtime",
    "lazy",
    "lepus",
    "src"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "build:publish-worklet-runtime": "pnpm run build:worklet-runtime && pnpm exec rslib build -c rslib.worklet-runtime.config.ts",
    "build:worklet-runtime": "tsc -b --force tsconfig.worklet-runtime.json",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@lynx-js/react": "workspace:*",
    "@lynx-js/react-transform": "workspace:*",
    "@lynx-js/types": "3.7.0",
    "@rslib/core": "catalog:",
    "@types/react": "^18.3.28",
    "pretty-format": "^30.2.0"
  },
  "peerDependencies": {
    "@types/react": "^18.0.0"
  },
  "showcase": "__fake_entry__/showcase.js"
}
