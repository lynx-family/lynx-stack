{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./lib",
    "baseUrl": "./",
    "paths": {
      "@lynx-js/react/worklet-runtime/bindings": [
        "./src/worklet-runtime/bindings/index.ts",
      ],
    },
    "rootDir": "./src",
    "jsx": "react-jsx",
    "jsxImportSource": "./",
  },
  "references": [{
    "path": "./tsconfig.worklet-runtime.json",
  }],
  "include": [
    "debug",
    "jsx-dev-runtime",
    "jsx-runtime",
    "lepus",
    "src",
    "types/types.d.ts",
    "types/internal-preact.d.ts",
  ],
  "exclude": [
    "src/worklet-runtime",
  ],
}
