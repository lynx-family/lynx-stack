{
  "name": "@lynx-js/react-worklet-runtime",
  "version": "0.0.1",
  "private": true,
  "description": "Worklet Runtime for ReactLynx 3.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./bindings": {
      "types": "./lib/bindings/index.d.ts",
      "default": "./lib/bindings/index.js"
    }
  },
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "typesVersions": {
    "*": {
      "bindings": [
        "./lib/bindings/index.d.ts"
      ]
    }
  },
  "files": [
    "CHANGELOG.md",
    "dist",
    "lib"
  ],
  "scripts": {
    "build": "rslib build",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@lynx-js/types": "3.7.0"
  }
}
