{
  "name": "@lynx-js/reactlynx-testing-library",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "rstest": "rstest",
    "test": "npm run test:base && npm run test:3.1",
    "test:3.1": "rstest run -c rstest.3.1.config.ts",
    "test:base": "rstest run"
  },
  "devDependencies": {
    "@lynx-js/react": "workspace:*",
    "@lynx-js/rspeedy": "workspace:*",
    "@lynx-js/testing-environment": "workspace:*",
    "@rsbuild/core": "catalog:rsbuild",
    "@rstest/adapter-rsbuild": "^0.2.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1"
  }
}
