{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": [
        "@lynx-js/react-transform#build:wasm",
        "@lynx-js/testing-environment#build",
        "@lynx-js/rspeedy#build"
      ],
      "inputs": [
        "loaders/**",
        "rslib.config.ts",
        "src/**",
        "types/**"
      ],
      "outputs": ["dist/**"]
    }
  }
}
