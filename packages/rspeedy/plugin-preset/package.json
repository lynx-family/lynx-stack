{
  "name": "@lynx-js/preset-rsbuild-plugin",
  "version": "0.1.0",
  "description": "An Rsbuild plugin that builds a Lynx app with the Rsbuild CLI directly, without the Rspeedy CLI.",
  "keywords": [
    "rsbuild",
    "Lynx",
    "ReactLynx",
    "preset"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lynx-family/lynx-stack.git",
    "directory": "packages/rspeedy/plugin-preset"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Yiming Li",
    "email": "yimingli.cs@gmail.com"
  },
  "type": "module",
  "imports": {
    "#register": {
      "types": "./register/index.d.ts",
      "import": "./register/index.js"
    }
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./internal": {
      "types": "./lib/internal.d.ts",
      "default": "./lib/internal.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./lib/index.d.ts",
  "files": [
    "client",
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "api-extractor": "api-extractor run --verbose",
    "build": "rslib build",
    "test": "rstest run",
    "test:type": "tsc --noEmit"
  },
  "dependencies": {
    "@lynx-js/cache-events-webpack-plugin": "workspace:^",
    "@lynx-js/chunk-loading-webpack-plugin": "workspace:^",
    "@lynx-js/debug-metadata-rsbuild-plugin": "workspace:*",
    "@lynx-js/web-rsbuild-server-middleware": "workspace:*",
    "@lynx-js/webpack-dev-transport": "workspace:^",
    "@lynx-js/websocket": "workspace:^",
    "@rsbuild/plugin-css-minimizer": "2.0.0",
    "@rsdoctor/rspack-plugin": "~1.5.6",
    "ipaddr.js": "^2.3.0",
    "picocolors": "^1.1.1",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@lynx-js/test-tools": "workspace:*",
    "@microsoft/api-extractor": "catalog:",
    "@rsbuild/core": "catalog:rsbuild",
    "@rsdoctor/core": "~1.5.6",
    "@rstest/core": "catalog:rstest",
    "@swc/core": "^1.15.30",
    "expect-type": "^1.2.1",
    "ts-blank-space": "^0.7.0",
    "type-fest": "^5.4.4",
    "typia": "12.1.1",
    "typia-rspack-plugin": "3.0.1"
  },
  "peerDependencies": {
    "@rsbuild/core": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./internal": {
        "types": "./dist/internal.d.ts",
        "default": "./dist/internal.js"
      },
      "./package.json": "./package.json"
    },
    "imports": {
      "#register": {
        "types": "./dist/register/index.d.ts",
        "import": "./dist/register/index.js"
      }
    },
    "types": "./dist/index.d.ts"
  }
}
