{
  "extends": ["./tsconfig.build.json"],
  "compilerOptions": {
    // Widened beyond the package (and `composite` turned off) because some
    // tests import the engine's TS sources from `../plugin-lynx/src` — rstest
    // aliases the engine package back to `src/` so mocks and the plugin under
    // test share one module instance, and `tsc --noEmit` must follow the same
    // resolution. This config is check-only; the build uses tsconfig.build.json.
    "composite": false,
    "rootDir": "../..",
    "noEmit": true,
  },
  "include": [
    "bin",
    "register",
    "src",
    "test",
    "client.d.ts",
    "package.json",
    "rstest.config.ts",
  ],
  "exclude": [
    "test/cli/fixtures",
    "test/config/fixtures",
  ],
  "references": [
    { "path": "../../webpack/cache-events-webpack-plugin/tsconfig.build.json" },
    { "path": "../../webpack/chunk-loading-webpack-plugin/tsconfig.build.json" },
    { "path": "../../webpack/css-extract-webpack-plugin/tsconfig.build.json" },
    { "path": "../plugin-debug-metadata/tsconfig.build.json" },
    { "path": "../../web-platform/web-rsbuild-server-middleware/tsconfig.json" },
  ],
}
