{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "plugins": [
      {
        "transform": "typia/lib/transform",
      },
    ],
    "strictNullChecks": true,
    "strict": true,
    "composite": true,
    "outDir": "./lib",
    // Keep incremental metadata with the generated lib output so stale
    // build info cannot outlive the files consumed by the dev CLI.
    "tsBuildInfoFile": "./lib/tsconfig.tsbuildinfo",
    "rootDir": "./src",
    "module": "nodenext",

    "resolveJsonModule": true,
  },
  "include": [
    "register",
    "src",
  ],
  "references": [
    { "path": "../plugin-preset/tsconfig.build.json" },
    { "path": "../plugin-debug-metadata/tsconfig.build.json" },
  ],
}
