{
  "name": "@lynx-js/debug-metadata-rsbuild-plugin",
  "version": "0.1.0",
  "description": "An rsbuild plugin that emits Lynx debug metadata (debug-metadata.json) alongside template builds.",
  "keywords": [
    "rsbuild",
    "Lynx",
    "debug",
    "sourcemap"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lynx-family/lynx-stack.git",
    "directory": "packages/rspeedy/plugin-debug-metadata"
  },
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./lib/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "api-extractor": "api-extractor run --verbose",
    "build": "rslib build",
    "test": "rstest"
  },
  "dependencies": {
    "@lynx-js/debug-metadata": "workspace:^"
  },
  "devDependencies": {
    "@lynx-js/template-webpack-plugin": "workspace:*",
    "@microsoft/api-extractor": "catalog:",
    "@rsbuild/core": "catalog:rsbuild"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./package.json": "./package.json"
    },
    "types": "./dist/index.d.ts"
  }
}
