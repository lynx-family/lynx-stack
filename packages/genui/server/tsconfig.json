{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "composite": false,
    "isolatedModules": true,
    "isolatedDeclarations": false,
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": true,
    "paths": {
      "@/*": [
        "./*",
      ],
    },
  },
  "include": [
    "**/*.ts",
    "**/*.mts",
  ],
  "exclude": [
    "dist",
    "node_modules",
  ],
}
