{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@lynx-js/react",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "noEmit": true,
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "../examples/**/*.ts",
    "../examples/**/*.tsx",
  ],
}
