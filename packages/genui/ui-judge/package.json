{
  "name": "@lynx-js/ui-judge",
  "version": "0.0.0",
  "private": true,
  "description": "GenUI UI judging utilities powered by Playwright and Midscene.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "api-extractor": "node ../scripts/run-api-extractor.mjs",
    "build": "rslib build",
    "test": "pnpm run test:playwright",
    "test:android": "vitest run --config vitest.config.ts",
    "test:playwright": "playwright test"
  },
  "dependencies": {
    "@lynx-js/genui": "workspace:*",
    "@midscene/core": "^1.8.0",
    "@midscene/web": "^1.8.0",
    "@playwright/test": "^1.58.2"
  },
  "devDependencies": {
    "@lynx-js/genui-a2ui": "workspace:*",
    "@lynx-js/genui-a2ui-catalog-extractor": "workspace:*",
    "@lynx-js/kitten-lynx-test-infra": "workspace:*",
    "@microsoft/api-extractor": "catalog:",
    "@types/node": "^24.10.13",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
