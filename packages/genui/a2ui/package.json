  "dependencies": {
    "@a2ui/web_core": "0.9.1",
    "@preact/signals": "^2.5.1"
  },
  "devDependencies": {
    "@lynx-js/a2ui-catalog-extractor": "workspace:*",
    "@lynx-js/lynx-ui": "^3.130.0",
    "@lynx-js/react": "workspace:*",
    "@lynx-js/types": "3.7.0",
    "@rstest/core": "catalog:rstest",
    "@types/react": "^18.3.28"
  },
  "peerDependencies": {
    "@lynx-js/lynx-ui": "^3.130.0",
    "@lynx-js/react": "workspace:^"
