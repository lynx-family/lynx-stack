{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**",
        "styles/**",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "api-extractor": {
      "dependsOn": [
        "//#build",
        "@lynx-js/genui-a2ui-catalog-extractor#build"
      ],
      "cache": false
    }
  }
}
