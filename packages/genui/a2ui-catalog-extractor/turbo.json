{
  "$schema": "https://turbo.build/schema.json",
  "extends": [
    "//"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**",
        "bin/**",
        "package.json",
        "rslib.config.ts",
        "tsconfig.build.json",
        "tsconfig.json"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "build:api": {
      "dependsOn": [],
      "inputs": [
        "src/**",
        "bin/**",
        "package.json",
        "rslib.config.ts",
        "tsconfig.build.json",
        "tsconfig.json"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "api-extractor": {
      "dependsOn": [
        "//#build",
        "build"
      ],
      "cache": false
    }
  }
}
