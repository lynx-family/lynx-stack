// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`encodeCSS > :root 1`] = `"[part="page"]:not([l-e-name]) {background:red;}"`;

exports[`encodeCSS > complex-root 1`] = `"[part="page"].dark:not([l-e-name]) {background:red;}"`;

exports[`encodeCSS > font-family-at-rule 1`] = `"@font-face {font-family:"MyFont";src:url('myfont.woff');}"`;

exports[`encodeCSS > normal css 1`] = `".foo:not([l-e-name]) {background:red;}"`;

exports[`encodeCSS > scoped css 1`] = `".foo:where([l-css-id="1"]):not([l-e-name]) {background:red;}"`;
