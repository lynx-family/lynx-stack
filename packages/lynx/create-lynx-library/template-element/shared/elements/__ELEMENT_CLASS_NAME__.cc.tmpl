#include "shared/elements/__ELEMENT_CLASS_NAME__.h"

#ifndef LYNX_NATIVE_ELEMENT_BACKEND_TEXTURE
#define LYNX_NATIVE_ELEMENT_BACKEND_TEXTURE 1
#endif

lynx_native_view_t* Create__ELEMENT_SYMBOL_NAME__TextureNativeView(void* opaque);
lynx_native_view_t* Create__ELEMENT_SYMBOL_NAME__NativeUINativeView(void* opaque);

lynx_native_view_t* Create__ELEMENT_SYMBOL_NAME__NativeView(void* opaque) {
  // Both element backend implementations are generated intentionally:
  // texture mode is better for compositor-owned rendering, while native-ui mode
  // is useful when embedding platform controls. Switch with
  // -DLYNX_NATIVE_ELEMENT_BACKEND=native-ui when configuring CMake.
#if LYNX_NATIVE_ELEMENT_BACKEND_TEXTURE
  return Create__ELEMENT_SYMBOL_NAME__TextureNativeView(opaque);
#else
  return Create__ELEMENT_SYMBOL_NAME__NativeUINativeView(opaque);
#endif
}
