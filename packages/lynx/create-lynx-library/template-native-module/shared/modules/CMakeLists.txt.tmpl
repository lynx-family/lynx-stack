file(GLOB LYNX_NATIVE_MODULE_SOURCES CONFIGURE_DEPENDS
  "${CMAKE_CURRENT_SOURCE_DIR}/*.cc"
)

add_library(__ADDON_TARGET_NAME__NativeModules OBJECT
  ${LYNX_NATIVE_MODULE_SOURCES}
)

target_include_directories(__ADDON_TARGET_NAME__NativeModules PRIVATE
  "${CMAKE_CURRENT_SOURCE_DIR}/../.."
  "${LYNX_EXTENSION_HEADERS_DIR}/include"
)

if(LYNX_LIBRARY_NODE_API_WEAK_SUFFIX)
  target_include_directories(__ADDON_TARGET_NAME__NativeModules PRIVATE
    "${LYNX_WEAK_NODE_API_HEADERS_DIR}"
  )
  target_compile_definitions(__ADDON_TARGET_NAME__NativeModules PRIVATE
    USE_WEAK_SUFFIX_NAPI=1
  )
endif()
