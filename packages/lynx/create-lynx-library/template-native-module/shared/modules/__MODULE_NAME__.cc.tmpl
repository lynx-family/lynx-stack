#include "shared/modules/__MODULE_NAME__.h"

#ifdef USE_WEAK_SUFFIX_NAPI
#include "weak_napi_defines.h"
#endif

#include <cstring>

namespace {

void Check(napi_env env, napi_status status) {
  if (status != napi_ok) {
    napi_throw_error(env, nullptr, "N-API call failed");
  }
}

napi_value Undefined(napi_env env) {
  napi_value result;
  Check(env, napi_get_undefined(env, &result));
  return result;
}

napi_value SetValue(napi_env env, napi_callback_info info) {
  return Undefined(env);
}

napi_value GetValue(napi_env env, napi_callback_info info) {
  napi_value result;
  Check(env, napi_get_null(env, &result));
  return result;
}

napi_value Clear(napi_env env, napi_callback_info info) {
  return Undefined(env);
}

void SetFunction(
    napi_env env,
    napi_value object,
    const char* name,
    napi_callback callback) {
  napi_value function;
  Check(env, napi_create_function(
    env,
    name,
    std::strlen(name),
    callback,
    nullptr,
    &function));
  Check(env, napi_set_named_property(env, object, name, function));
}

}  // namespace

void Bind__MODULE_SYMBOL_NAME__(napi_env env, napi_value exports) {
  SetFunction(env, exports, "setValue", SetValue);
  SetFunction(env, exports, "getValue", GetValue);
  SetFunction(env, exports, "clear", Clear);
}

#ifdef USE_WEAK_SUFFIX_NAPI
#include "weak_napi_undefs.h"
#endif
