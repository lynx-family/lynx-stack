{
  "extends": ["./tsconfig.build.json"],
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,

    // TODO: enable isolatedDeclarations with allowJs disabled
    "isolatedDeclarations": false,
    "allowJs": true,
    "checkJs": true,
  },
  "include": [
    "runtime",
    "src",
    "test",
    "rstest.config.ts",
  ],
  // Test-run build output, not sources.
  "exclude": [
    "test/dist",
    "test/js",
  ],
  "references": [
    { "path": "../template-webpack-plugin/tsconfig.build.json" },
  ],
}
