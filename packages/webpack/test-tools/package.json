{
  "name": "@lynx-js/test-tools",
  "version": "0.0.0",
  "private": true,
  "description": "A test runner for testing Lynx-related rspack & webpack plugins",
  "keywords": [
    "rspack",
    "webpack",
    "Lynx"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "Qingyu Wang",
    "email": "colinwang.0616@gmail.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./rstest-config": {
      "types": "./lib/rstest-config.d.ts",
      "default": "./lib/rstest-config.js"
    },
    "./setup-file-snapshot": {
      "types": "./lib/setup-file-snapshot.d.ts",
      "default": "./lib/setup-file-snapshot.js"
    },
    "./setup-rspeedy": {
      "types": "./lib/setup-rspeedy.d.ts",
      "default": "./lib/setup-rspeedy.js"
    },
    "./helper/*": "./lib/helper/*",
    "./update.js": "./update.js",
    "./package.json": "./package.json"
  },
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {},
  "devDependencies": {
    "@rspack/core": "catalog:rspack",
    "@rspack/test-tools": "catalog:rspack",
    "@rstest/core": "catalog:rstest",
    "@types/fs-extra": "11.0.4",
    "fs-extra": "^11.3.3",
    "path-serializer": "^0.6.0",
    "rimraf": "^6.1.3",
    "source-map": "^0.7.6",
    "tiny-invariant": "^1.3.3",
    "webpack-merge": "^6.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
